<RelativeLayout 
    id="@+id/main"
    layout_width="match_parent"
    layout_height="@dimen/_380sdp"
    layout_gravity="center_vertical"
    >


    <ImageView
        layout_width="match_parent"
        layout_height="match_parent"
        scaleType="fitXY"
        src="@drawable/ic_temp7_bg" />



    <LinearLayout
        layout_width="match_parent"
        layout_height="wrap_content"
        weightSum="3"
        layout_alignParentBottom="true"
        layout_marginBottom="@dimen/_30sdp"
        paddingHorizontal="@dimen/_minus8sdp"
        orientation="horizontal">

        <FrameLayout
            layout_width="0dp"
            layout_weight="1"
            layout_gravity="bottom"
            layout_height="@dimen/_125sdp"
            >

            <com.appblish.templates.TemplateShapeView
                id="@+id/shape1"
                layout_width="match_parent"
                layout_height="match_parent"
                shapeDrawable="@drawable/custum_temp7_frame1" />

            <ImageView
                layout_width="match_parent"
                layout_height="match_parent"
                scaleType="fitXY"
                src="@drawable/custum_temp7_frame1_strock" />

        </FrameLayout>

        <FrameLayout
            layout_width="0dp"
            layout_weight="1"
            layout_height="@dimen/_140sdp"
            layout_marginBottom="@dimen/_20sdp"
            >

            <com.appblish.templates.TemplateShapeView
                id="@+id/shape2"
                layout_width="match_parent"
                layout_height="match_parent"
                shapeDrawable="@drawable/custum_temp7_frame2" />

            <ImageView
                layout_width="match_parent"
                layout_height="match_parent"
                scaleType="fitXY"
                src="@drawable/custum_temp7_frame1_strock" />

        </FrameLayout>
        <FrameLayout
            layout_width="0dp"
            layout_weight="1"
            layout_gravity="bottom"
            layout_height="@dimen/_125sdp"
            >

            <com.appblish.templates.TemplateShapeView
                id="@+id/shape3"
                layout_width="match_parent"
                layout_height="match_parent"
                shapeDrawable="@drawable/custum_temp7_frame3" />

            <ImageView
                layout_width="match_parent"
                layout_height="match_parent"
                scaleType="fitXY"
                src="@drawable/custum_temp7_frame3_strock" />
            <ImageView
                layout_width="@dimen/_55sdp"
                layout_height="wrap_content"
                adjustViewBounds="true"
                layout_marginStart="@dimen/_minus15sdp"
                src="@drawable/ic_temp7_top2_img" />
        </FrameLayout>
    </LinearLayout>


    <ImageView
        layout_width="@dimen/_55sdp"
        layout_height="wrap_content"
        adjustViewBounds="true"
        layout_alignParentBottom="true"
        layout_marginBottom="@dimen/_135sdp"
        layout_marginStart="@dimen/_60sdp"
        src="@drawable/ic_temp7_top1_img" />


    <ImageView
        layout_width="match_parent"
        layout_height="@dimen/_145sdp"
        layout_centerHorizontal="true"
        layout_marginTop="@dimen/_25sdp"
        src="@drawable/ic_temp7_holi_img" />
    <ImageView
        layout_width="@dimen/_55sdp"
        layout_height="wrap_content"
        layout_alignParentBottom="true"
        adjustViewBounds="true"
        layout_marginBottom="@dimen/_10sdp"
        src="@drawable/ic_temp7_left_img" />

    <ImageView
        layout_width="@dimen/_200sdp"
        layout_height="wrap_content"
        layout_alignParentBottom="true"
        layout_alignParentEnd="true"
        adjustViewBounds="true"
        layout_marginBottom="@dimen/_minus12sdp"
        src="@drawable/ic_temp7_bottom_img" />

</RelativeLayout>