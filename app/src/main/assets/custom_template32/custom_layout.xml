<RelativeLayout 
    id="@+id/main"
    layout_width="match_parent"
    layout_height="@dimen/_310sdp"
    layout_gravity="center_vertical"
    >


    <ImageView
        layout_width="match_parent"
        layout_height="match_parent"
        scaleType="fitXY"
        src="@drawable/ic_temp32_bg" />


    <FrameLayout
        layout_width="match_parent"
        layout_height="@dimen/_215sdp"
        layout_alignParentBottom="true"
        layout_marginHorizontal="@dimen/_50sdp"
        >

        <com.appblish.templates.TemplateShapeView
            id="@+id/shape1"
            layout_width="match_parent"
            layout_height="match_parent"
            shapeDrawable="@drawable/costom_temp32_shape" />

        <ImageView
            layout_width="match_parent"
            layout_height="match_parent"
            scaleType="fitXY"
            src="@drawable/costom_temp32_shape_stroke" />

    </FrameLayout>




    <ImageView
        layout_width="@dimen/_100sdp"
        layout_height="wrap_content"
        layout_alignParentBottom="true"
        adjustViewBounds="true"
        src="@drawable/ic_temp32_ele1" />

    <ImageView
        layout_width="@dimen/_100sdp"
        layout_height="wrap_content"
        layout_alignParentBottom="true"
        layout_alignParentEnd="true"
        adjustViewBounds="true"
        layout_marginBottom="@dimen/_minus5sdp"
        src="@drawable/ic_temp32_ele2" />
</RelativeLayout>