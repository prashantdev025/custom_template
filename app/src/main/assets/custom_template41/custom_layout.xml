<RelativeLayout 
    id="@+id/main"
    layout_width="match_parent"
    layout_height="@dimen/_350sdp"
    layout_gravity="center_vertical"
    background="#FFFFFF">


    <RelativeLayout
        layout_width="match_parent"
        layout_height="@dimen/_180sdp"
        orientation="horizontal">

        <FrameLayout
            layout_width="@dimen/_170sdp"
            layout_height="match_parent"
            layout_marginStart="-15dp"
            layout_marginTop="-8dp">

            <com.appblish.templates.TemplateShapeView
                id="@+id/shape1"
                layout_width="match_parent"
                layout_height="match_parent"
                shapeDrawable="@drawable/custom_temp41_shape" />

            <ImageView
                layout_width="match_parent"
                layout_height="match_parent"
                scaleType="fitXY"
                src="@drawable/custom_temp41_shape_stroke" />

        </FrameLayout>

        <FrameLayout
            layout_width="@dimen/_200sdp"
            layout_height="match_parent"
            layout_alignParentEnd="true"
            layout_marginTop="-15dp"
            layout_marginEnd="-22dp">

            <com.appblish.templates.TemplateShapeView
                id="@+id/shape2"
                layout_width="match_parent"
                layout_height="match_parent"
                shapeDrawable="@drawable/custom_temp41_shape2" />

            <ImageView
                layout_width="match_parent"
                layout_height="match_parent"
                scaleType="fitXY"
                src="@drawable/custom_temp41_shape2_stroke" />

        </FrameLayout>

    </RelativeLayout>

    <RelativeLayout
        layout_width="match_parent"
        layout_height="@dimen/_180sdp"
        layout_marginTop="@dimen/_170sdp"
        orientation="horizontal">

        <FrameLayout
            layout_width="@dimen/_170sdp"
            layout_height="match_parent"
            layout_marginStart="-15dp"
            layout_marginTop="-8dp">

            <com.appblish.templates.TemplateShapeView
                id="@+id/shape3"
                layout_width="match_parent"
                layout_height="match_parent"
                shapeDrawable="@drawable/custom_temp41_shape" />

            <ImageView
                layout_width="match_parent"
                layout_height="match_parent"
                scaleType="fitXY"
                src="@drawable/custom_temp41_shape_stroke" />

        </FrameLayout>

        <FrameLayout
            layout_width="@dimen/_200sdp"
            layout_height="match_parent"
            layout_alignParentEnd="true"
            layout_marginEnd="-22dp"
            layout_marginBottom="-15dp">

            <com.appblish.templates.TemplateShapeView
                id="@+id/shape4"
                layout_width="match_parent"
                layout_height="match_parent"
                shapeDrawable="@drawable/custom_temp41_shape2" />

            <ImageView
                layout_width="match_parent"
                layout_height="match_parent"
                scaleType="fitXY"
                src="@drawable/custom_temp41_shape2_stroke" />

        </FrameLayout>

    </RelativeLayout>


    <ImageView
        layout_width="@dimen/_100sdp"
        layout_height="@dimen/_100sdp"
        layout_centerInParent="true"
        src="@drawable/frame41_ele1" />
</RelativeLayout>