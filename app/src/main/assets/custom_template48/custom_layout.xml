<RelativeLayout 
    id="@+id/main"
    layout_width="match_parent"
    layout_height="@dimen/_310sdp"
    layout_gravity="center_vertical">


    <ImageView
        layout_width="match_parent"
        layout_height="match_parent"
        scaleType="fitXY"
        src="@drawable/frame48_bg" />


    <RelativeLayout
        layout_width="match_parent"
        layout_height="@dimen/_260sdp"
        layout_alignParentBottom="true"
        layout_marginBottom="@dimen/_15sdp">

        <FrameLayout
            layout_width="@dimen/_110sdp"
            layout_height="@dimen/_90sdp"
            layout_marginStart="@dimen/_20sdp"
            layout_marginTop="@dimen/_20sdp"
            elevation="@dimen/_6sdp">

            <com.editor.template.utils.CollageShapeView
                id="@+id/shape1"
                layout_width="match_parent"
                layout_height="match_parent"
                shapeDrawable="@drawable/custom_temp48_shape1" />

            <ImageView
                layout_width="match_parent"
                layout_height="match_parent"
                scaleType="fitXY"
                src="@drawable/custom_temp48_shape1_stroke" />

        </FrameLayout>

        <FrameLayout
            id="@+id/f2"
            layout_width="@dimen/_140sdp"
            layout_height="@dimen/_75sdp"
            layout_marginStart="@dimen/_10sdp"
            layout_marginTop="@dimen/_85sdp"
            elevation="@dimen/_5sdp">

            <com.editor.template.utils.CollageShapeView
                id="@+id/shape2"
                layout_width="match_parent"
                layout_height="match_parent"
                shapeDrawable="@drawable/custom_temp48_shape2" />

            <ImageView
                layout_width="match_parent"
                layout_height="match_parent"
                scaleType="fitXY"
                src="@drawable/custom_temp48_shape2_stroke" />

        </FrameLayout>

        <FrameLayout
            id="@+id/f3"
            layout_width="@dimen/_135sdp"
            layout_height="@dimen/_95sdp"
            layout_below="@+id/f2"
            layout_marginStart="@dimen/_40sdp"
            layout_marginTop="@dimen/_minus10sdp">

            <com.editor.template.utils.CollageShapeView
                id="@+id/shape3"
                layout_width="match_parent"
                layout_height="match_parent"
                shapeDrawable="@drawable/custom_temp48_shape3" />

            <ImageView
                layout_width="match_parent"
                layout_height="match_parent"
                scaleType="fitXY"
                src="@drawable/custom_temp48_shape3_stroke" />

        </FrameLayout>

        <FrameLayout
            id="@+id/f4"
            layout_width="@dimen/_145sdp"
            layout_height="@dimen/_110sdp"
            layout_alignParentEnd="true"
            layout_marginEnd="@dimen/_25sdp">

            <com.editor.template.utils.CollageShapeView
                id="@+id/shape4"
                layout_width="match_parent"
                layout_height="match_parent"
                shapeDrawable="@drawable/custom_temp48_shape4" />

            <ImageView
                layout_width="match_parent"
                layout_height="match_parent"
                scaleType="fitXY"
                src="@drawable/custom_temp48_shape4_stroke" />

        </FrameLayout>

        <FrameLayout
            id="@+id/f5"
            layout_width="@dimen/_125sdp"
            layout_height="@dimen/_100sdp"
            layout_below="@+id/f4"
            layout_alignParentEnd="true"
            layout_marginTop="@dimen/_10sdp"
            layout_marginEnd="@dimen/_25sdp"
            elevation="@dimen/_5sdp">

            <com.editor.template.utils.CollageShapeView
                id="@+id/shape5"
                layout_width="match_parent"
                layout_height="match_parent"
                shapeDrawable="@drawable/custom_temp48_shape5" />

            <ImageView
                layout_width="match_parent"
                layout_height="match_parent"
                scaleType="fitXY"
                src="@drawable/custom_temp48_shape5_stroke" />

        </FrameLayout>

    </RelativeLayout>

    <ImageView
        layout_width="@dimen/_130sdp"
        layout_height="wrap_content"
        layout_alignParentEnd="true"
        layout_alignParentBottom="true"
        adjustViewBounds="true"
        src="@drawable/frame48_ele2" />

    <ImageView
        layout_width="@dimen/_130sdp"
        layout_height="wrap_content"
        layout_alignParentBottom="true"
        layout_marginBottom="@dimen/_5sdp"
        adjustViewBounds="true"
        src="@drawable/frame48_ele3" />

    <ImageView
        layout_width="@dimen/_180sdp"
        layout_height="wrap_content"
        adjustViewBounds="true"
        padding="@dimen/_5sdp"
        src="@drawable/frame48_ele1" />

    <ImageView
        layout_width="@dimen/_60sdp"
        layout_height="wrap_content"
        layout_alignParentEnd="true"
        layout_marginTop="@dimen/_10sdp"
        layout_marginEnd="@dimen/_5sdp"
        adjustViewBounds="true"
        padding="@dimen/_5sdp"
        src="@drawable/frame48_ele4" />

</RelativeLayout>