<RelativeLayout 
    id="@+id/main"
    layout_width="match_parent"
    layout_height="@dimen/_310sdp"
    layout_gravity="center_vertical">


    <FrameLayout
        layout_width="match_parent"
        layout_height="match_parent"
        layout_centerInParent="true">

        <com.editor.template.utils.CollageShapeView
            id="@+id/shape1"
            layout_width="match_parent"
            layout_height="match_parent"
            shapeDrawable="@drawable/custom_temp40_shape" />

        <ImageView
            layout_width="match_parent"
            layout_height="match_parent"
            scaleType="fitXY"
            src="@drawable/custom_temp40_shape_strock" />

    </FrameLayout>


    <ImageView
        layout_width="match_parent"
        layout_height="wrap_content"
        layout_alignParentEnd="false"
        layout_alignParentBottom="true"
        adjustViewBounds="true"
        src="@drawable/frame40_ele1" />


</RelativeLayout>