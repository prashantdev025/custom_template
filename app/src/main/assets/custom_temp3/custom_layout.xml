<RelativeLayout 
    id="@+id/main"
    layout_width="match_parent"
    layout_height="match_parent"
    layout_gravity="center_vertical"
    >


    <ImageView
        layout_width="match_parent"
        layout_height="match_parent"
        scaleType="fitXY"
        src="@drawable/ic_bg_temp3" />

    <ImageView
        layout_width="match_parent"
        layout_height="@dimen/_220sdp"
        layout_centerInParent="true"
        src="@drawable/custum_temp3_frame"/>

    <FrameLayout
        layout_width="match_parent"
        layout_height="@dimen/_220sdp"
        layout_centerInParent="true"
    >

        <com.picture.mygallery.ui.custom.CollageShapeView
            id="@+id/shape1"
            layout_width="match_parent"
            layout_height="match_parent"
            shapeDrawable="@drawable/custum_temp3_frame_stroke" />

        <ImageView
            layout_width="match_parent"
            layout_height="match_parent"
            layout_marginHorizontal="@dimen/_12sdp"
            layout_marginTop="@dimen/_minus6sdp"
            src="@drawable/custum_temp3_frame_stroke" />

    </FrameLayout>


    <ImageView
        layout_width="match_parent"
        layout_height="wrap_content"
        adjustViewBounds="true"
        src="@drawable/ic_top_temp3" />


    <ImageView
        layout_width="match_parent"
        layout_height="wrap_content"
        layout_alignParentBottom="true"
        adjustViewBounds="true"
        paddingHorizontal="@dimen/_minus25sdp"
        src="@drawable/ic_bottom_temp3" />


</RelativeLayout>