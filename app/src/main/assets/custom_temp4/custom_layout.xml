<RelativeLayout
    id="@+id/main"
    layout_width="match_parent"
    layout_height="@dimen/_380sdp"
    layout_gravity="center_vertical"
    >


    <ImageView
        layout_width="match_parent"
        layout_height="match_parent"
        scaleType="fitXY"
        src="@drawable/ic_temp4_bg" />


    <FrameLayout
        layout_width="@dimen/_205sdp"
        layout_height="@dimen/_110sdp"
        layout_centerHorizontal="true"
        layout_marginTop="@dimen/_52sdp">

        <com.editor.template.utils.CollageShapeView
            id="@+id/shape1"
            layout_width="match_parent"
            layout_height="match_parent"
            shapeDrawable="@drawable/custum_temp4_shape" />

        <ImageView
            layout_width="match_parent"
            layout_height="match_parent"
            scaleType="fitXY"
            src="@drawable/custum_temp4_shape_stroke" />

    </FrameLayout>


    <ImageView
        layout_width="@dimen/_60sdp"
        layout_height="@dimen/_50sdp"
        layout_centerHorizontal="true"
        layout_marginTop="@dimen/_10sdp"
        src="@drawable/ic_temp4_helloween" />


</RelativeLayout>