<RelativeLayout 
    id="@+id/main"
    layout_width="match_parent"
    layout_height="@dimen/_205sdp"
    layout_gravity="center_vertical"
    >


    <ImageView
        layout_width="match_parent"
        layout_height="match_parent"
        scaleType="fitXY"
        src="@drawable/ic_temp9_bg" />


    <FrameLayout
        layout_width="@dimen/_110sdp"
        layout_height="@dimen/_68sdp"
        layout_alignParentBottom="true"
        layout_centerHorizontal="true"
        layout_marginBottom="@dimen/_3sdp">

        <com.appblish.templates.TemplateShapeView
            id="@+id/shape1"
            layout_width="match_parent"
            layout_height="match_parent"
            shapeDrawable="@drawable/custum_temp9_round" />

        <ImageView
            layout_width="match_parent"
            layout_height="match_parent"
            scaleType="fitXY"
            src="@drawable/custum_temp9_round_stroke" />

    </FrameLayout>


</RelativeLayout>