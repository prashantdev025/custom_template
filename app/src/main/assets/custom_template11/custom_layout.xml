<RelativeLayout
    id="@+id/main"
    layout_width="match_parent"
    layout_height="@dimen/_380sdp"
    layout_gravity="center_vertical"
    >


    <ImageView
        layout_width="match_parent"
        layout_height="match_parent"
        scaleType="fitXY"
        src="@drawable/ic_temp11_bg" />

    <LinearLayout
        layout_width="wrap_content"
        layout_height="wrap_content"
        layout_centerHorizontal="true"
        layout_marginTop="@dimen/_60sdp"
        orientation="vertical">

        <LinearLayout
            layout_width="wrap_content"
            layout_height="0dp"
            orientation="horizontal"
            weightSum="2"
            padding="@dimen/_3sdp"
            layout_weight="1">
            <FrameLayout
                layout_width="@dimen/_90sdp"
                layout_height="@dimen/_90sdp"
                >

                <com.appblish.templates.TemplateShapeView
                    id="@+id/shape1"
                    layout_width="match_parent"
                    layout_height="match_parent"
                    shapeDrawable="@drawable/custum_temp11_shape1" />

                <ImageView
                    layout_width="match_parent"
                    layout_height="match_parent"
                    scaleType="fitXY"
                    src="@drawable/custum_temp11_shape1_strock" />

            </FrameLayout>
            <LinearLayout
                layout_width="@dimen/_45sdp"
                layout_height="@dimen/_90sdp"
                orientation="vertical"
                weightSum="2"
                >
                <FrameLayout
                    layout_width="match_parent"
                    layout_weight="1"
                    padding="@dimen/_3sdp"
                    layout_height="0dp"
                    >

                    <com.appblish.templates.TemplateShapeView
                        id="@+id/shape3"
                        layout_width="match_parent"
                        layout_height="match_parent"
                        shapeDrawable="@drawable/custum_temp11_shape1" />

                    <ImageView
                        layout_width="match_parent"
                        layout_height="match_parent"
                        scaleType="fitXY"
                        src="@drawable/custum_temp11_shape1_strock" />

                </FrameLayout>

                <FrameLayout
                    layout_width="match_parent"
                    layout_weight="1"
                    padding="@dimen/_3sdp"
                    layout_height="0dp"
                    >

                    <com.appblish.templates.TemplateShapeView
                        id="@+id/shape2"
                        layout_width="match_parent"
                        layout_height="match_parent"
                        shapeDrawable="@drawable/custum_temp11_shape1" />

                    <ImageView
                        layout_width="match_parent"
                        layout_height="match_parent"
                        scaleType="fitXY"
                        src="@drawable/custum_temp11_shape1_strock" />

                </FrameLayout>
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            layout_width="wrap_content"
            layout_height="0dp"
            orientation="horizontal"
            weightSum="2"
            padding="@dimen/_3sdp"
            layout_weight="1">
            <LinearLayout
                layout_width="@dimen/_45sdp"
                layout_height="@dimen/_90sdp"
                orientation="vertical"
                weightSum="2"
                >
                <FrameLayout
                    layout_width="match_parent"
                    layout_weight="1"
                    padding="@dimen/_3sdp"
                    layout_height="0dp"
                    >

                    <com.appblish.templates.TemplateShapeView
                        id="@+id/shape4"
                        layout_width="match_parent"
                        layout_height="match_parent"
                        shapeDrawable="@drawable/custum_temp11_shape1" />

                    <ImageView
                        layout_width="match_parent"
                        layout_height="match_parent"
                        scaleType="fitXY"
                        src="@drawable/custum_temp11_shape1_strock" />

                </FrameLayout>

                <FrameLayout
                    layout_width="match_parent"
                    layout_weight="1"
                    padding="@dimen/_3sdp"
                    layout_height="0dp"
                    >

                    <com.appblish.templates.TemplateShapeView
                        id="@+id/shape5"
                        layout_width="match_parent"
                        layout_height="match_parent"
                        shapeDrawable="@drawable/custum_temp11_shape1" />

                    <ImageView
                        layout_width="match_parent"
                        layout_height="match_parent"
                        scaleType="fitXY"
                        src="@drawable/custum_temp11_shape1_strock" />

                </FrameLayout>
            </LinearLayout>
            <FrameLayout
                layout_width="@dimen/_90sdp"
                layout_height="@dimen/_90sdp"
                >

                <com.appblish.templates.TemplateShapeView
                    id="@+id/shape6"
                    layout_width="match_parent"
                    layout_height="match_parent"
                    shapeDrawable="@drawable/custum_temp11_shape1" />

                <ImageView
                    layout_width="match_parent"
                    layout_height="match_parent"
                    scaleType="fitXY"
                    src="@drawable/custum_temp11_shape1_strock" />

            </FrameLayout>


        </LinearLayout>

    </LinearLayout>


</RelativeLayout>