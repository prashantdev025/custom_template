<RelativeLayout
    id="@+id/main"
    layout_width="match_parent"
    layout_height="@dimen/_165sdp"
    layout_gravity="center_vertical">


    <ImageView
        layout_width="match_parent"
        layout_height="match_parent"
        scaleType="fitXY"
        src="@drawable/frame39_bg" />

    <RelativeLayout
        layout_width="match_parent"
        layout_height="wrap_content"
        layout_centerHorizontal="true"
        layout_marginHorizontal="@dimen/_30sdp"
        layout_marginTop="@dimen/_20sdp">


        <FrameLayout
            layout_width="@dimen/_150sdp"
            layout_height="@dimen/_110sdp"
            layout_centerHorizontal="true">

            <com.editor.template.utils.CollageShapeView
                id="@+id/shape2"
                layout_width="match_parent"
                layout_height="match_parent"
                shapeDrawable="@drawable/custom_temp39_shape2" />

            <ImageView
                layout_width="match_parent"
                layout_height="match_parent"
                scaleType="fitXY"
                src="@drawable/custom_temp39_shape2_stroke" />

        </FrameLayout>

        <FrameLayout
            layout_width="@dimen/_85sdp"
            layout_height="@dimen/_110sdp"
            layout_alignParentEnd="true"
            layout_centerVertical="true"
            layout_marginTop="@dimen/_35sdp"
            elevation="@dimen/_5sdp">

            <com.editor.template.utils.CollageShapeView
                id="@+id/shape1"
                layout_width="match_parent"
                layout_height="match_parent"
                shapeDrawable="@drawable/custom_temp39_shape3" />

            <ImageView
                layout_width="match_parent"
                layout_height="match_parent"
                scaleType="fitXY"
                src="@drawable/custom_temp39_shape3_stroke" />

        </FrameLayout>

        <FrameLayout
            layout_width="@dimen/_80sdp"
            layout_height="@dimen/_110sdp"
            layout_marginTop="@dimen/_10sdp">

            <com.editor.template.utils.CollageShapeView
                id="@+id/shape3"
                layout_width="match_parent"
                layout_height="match_parent"
                shapeDrawable="@drawable/custom_temp39_shape1" />

            <ImageView
                layout_width="match_parent"
                layout_height="match_parent"
                scaleType="fitXY"
                src="@drawable/custom_temp39_shape1_stroke" />

        </FrameLayout>


    </RelativeLayout>

    <ImageView
        layout_width="@dimen/_90sdp"
        layout_height="@dimen/_60sdp"
        layout_alignParentEnd="true"
        layout_alignParentBottom="true"
        layout_marginEnd="@dimen/_10sdp"
        adjustViewBounds="true"
        src="@drawable/frame_ele4" />

    <ImageView
        layout_width="@dimen/_80sdp"
        layout_height="@dimen/_55sdp"
        adjustViewBounds="true"
        src="@drawable/frame_ele1" />

    <ImageView
        layout_width="@dimen/_35sdp"
        layout_height="@dimen/_35sdp"
        layout_marginStart="@dimen/_70sdp"
        layout_marginTop="@dimen/_15sdp"
        adjustViewBounds="true"
        padding="@dimen/_5sdp"
        src="@drawable/frame_ele2" />

    <ImageView
        layout_width="@dimen/_50sdp"
        layout_height="@dimen/_50sdp"
        layout_alignParentBottom="true"
        layout_marginEnd="@dimen/_10sdp"
        layout_marginBottom="@dimen/_30sdp"
        adjustViewBounds="true"
        src="@drawable/frame_ele3" />

</RelativeLayout>