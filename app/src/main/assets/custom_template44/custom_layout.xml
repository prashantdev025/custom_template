<RelativeLayout 
    id="@+id/main"
    layout_width="match_parent"
    layout_height="@dimen/_310sdp"
    layout_gravity="center_vertical">


    <ImageView
        layout_width="match_parent"
        layout_height="match_parent"
        scaleType="fitXY"
        src="@drawable/frame44_bg" />

    <LinearLayout
        layout_width="match_parent"
        layout_height="match_parent"
        orientation="vertical">

        <LinearLayout
            layout_width="match_parent"
            layout_height="0dp"
            layout_weight="1"
            orientation="horizontal"
        >

            <FrameLayout
                layout_width="0dp"
                layout_weight="1"
                layout_height="match_parent"
            >

                <com.appblish.templates.TemplateShapeView
                    id="@+id/shape1"
                    layout_width="match_parent"
                    layout_height="match_parent"
                    shapeDrawable="@drawable/custom_temp44_shape1" />

                <ImageView
                    layout_width="match_parent"
                    layout_height="match_parent"
                    scaleType="fitXY"
                    src="@drawable/custom_temp44_shape1_stroke" />

            </FrameLayout>
            <FrameLayout
                layout_width="0dp"
                layout_weight="1"
                rotation="15"
                layout_marginStart="@dimen/_minus5sdp"
                layout_height="match_parent"
            >

                <com.appblish.templates.TemplateShapeView
                    id="@+id/shape2"
                    layout_width="match_parent"
                    layout_height="match_parent"
                    shapeDrawable="@drawable/custom_temp44_shape1" />

                <ImageView
                    layout_width="match_parent"
                    layout_height="match_parent"
                    scaleType="fitXY"
                    src="@drawable/custom_temp44_shape1_stroke" />

            </FrameLayout>
            <FrameLayout
                layout_width="0dp"
                layout_weight="1"
                layout_height="match_parent"
            >

                <com.appblish.templates.TemplateShapeView
                    id="@+id/shape3"
                    layout_width="match_parent"
                    layout_height="match_parent"
                    shapeDrawable="@drawable/custom_temp44_shape1" />

                <ImageView
                    layout_width="match_parent"
                    layout_height="match_parent"
                    scaleType="fitXY"
                    src="@drawable/custom_temp44_shape1_stroke" />

            </FrameLayout>

        </LinearLayout>

        <LinearLayout
            layout_width="match_parent"
            layout_height="0dp"
            layout_weight="1"
            orientation="horizontal"
        >

            <FrameLayout
                layout_width="0dp"
                layout_weight="1"
                layout_marginStart="@dimen/_minus10sdp"
                layout_height="match_parent"
            >

                <com.appblish.templates.TemplateShapeView
                    id="@+id/shape4"
                    layout_width="match_parent"
                    layout_height="match_parent"
                    shapeDrawable="@drawable/custom_temp44_shape1" />

                <ImageView
                    layout_width="match_parent"
                    layout_height="match_parent"
                    scaleType="fitXY"
                    src="@drawable/custom_temp44_shape1_stroke" />

            </FrameLayout>
            <FrameLayout
                layout_width="0dp"
                layout_weight="1"
                layout_height="match_parent"
            >


            </FrameLayout>
            <FrameLayout
                layout_width="0dp"
                layout_weight="1"
                layout_marginEnd="@dimen/_minus10sdp"
                rotation="20"
                layout_height="match_parent"
            >

                <com.appblish.templates.TemplateShapeView
                    id="@+id/shape5"
                    layout_width="match_parent"
                    layout_height="match_parent"
                    shapeDrawable="@drawable/custom_temp44_shape1" />

                <ImageView
                    layout_width="match_parent"
                    layout_height="match_parent"
                    scaleType="fitXY"
                    src="@drawable/custom_temp44_shape1_stroke" />

            </FrameLayout>

        </LinearLayout>

        <LinearLayout
            layout_width="match_parent"
            layout_height="0dp"
            layout_weight="1"
            layout_marginTop="@dimen/_minus5sdp"
            orientation="horizontal"
        >

            <FrameLayout
                layout_width="0dp"
                layout_weight="1"
                layout_height="match_parent"
            >

                <com.appblish.templates.TemplateShapeView
                    id="@+id/shape6"
                    layout_width="match_parent"
                    layout_height="match_parent"
                    shapeDrawable="@drawable/custom_temp44_shape1" />

                <ImageView
                    layout_width="match_parent"
                    layout_height="match_parent"
                    scaleType="fitXY"
                    src="@drawable/custom_temp44_shape1_stroke" />

            </FrameLayout>
            <FrameLayout
                layout_width="0dp"
                layout_weight="1"
                rotation="15"
                layout_height="match_parent"
            >

                <com.appblish.templates.TemplateShapeView
                    id="@+id/shape7"
                    layout_width="match_parent"
                    layout_height="match_parent"
                    shapeDrawable="@drawable/custom_temp44_shape1" />

                <ImageView
                    layout_width="match_parent"
                    layout_height="match_parent"
                    scaleType="fitXY"
                    src="@drawable/custom_temp44_shape1_stroke" />

            </FrameLayout>
            <FrameLayout
                layout_width="0dp"
                layout_weight="1"
                layout_height="match_parent"
            >

                <com.appblish.templates.TemplateShapeView
                    id="@+id/shape8"
                    layout_width="match_parent"
                    layout_height="match_parent"
                    shapeDrawable="@drawable/custom_temp44_shape1" />

                <ImageView
                    layout_width="match_parent"
                    layout_height="match_parent"
                    scaleType="fitXY"
                    src="@drawable/custom_temp44_shape1_stroke" />

            </FrameLayout>

        </LinearLayout>


    </LinearLayout>





</RelativeLayout>