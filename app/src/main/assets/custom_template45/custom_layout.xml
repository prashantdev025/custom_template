<RelativeLayout 
    id="@+id/main"
    layout_width="match_parent"
    layout_height="@dimen/_350sdp"
    layout_gravity="center_vertical">


    <ImageView
        layout_width="match_parent"
        layout_height="match_parent"
        scaleType="fitXY"
        src="@drawable/frame45_bg" />

    <RelativeLayout
        layout_width="@dimen/_230sdp"
        layout_height="@dimen/_300sdp"
        layout_centerInParent="true"
        >


        <FrameLayout
            layout_width="@dimen/_125sdp"
            layout_height="@dimen/_150sdp"
            layout_marginTop="@dimen/_25sdp">

            <com.editor.template.utils.CollageShapeView
                id="@+id/shape1"
                layout_width="match_parent"
                layout_height="match_parent"
                layout_margin="@dimen/_10sdp"
                shapeDrawable="@drawable/custom_temp45_shape1" />

            <ImageView
                layout_width="match_parent"
                layout_height="match_parent"
                scaleType="fitXY"
                src="@drawable/custom_temp45_shape1_stroke" />

        </FrameLayout>

        <FrameLayout
            layout_width="@dimen/_120sdp"
            layout_height="@dimen/_140sdp"
            layout_alignParentBottom="true"
            elevation="@dimen/_5sdp"
            layout_marginStart="@dimen/_20sdp"
            layout_marginBottom="@dimen/_20sdp"
            >

            <com.editor.template.utils.CollageShapeView
                id="@+id/shape3"
                layout_width="match_parent"
                layout_height="match_parent"
                layout_margin="@dimen/_10sdp"
                shapeDrawable="@drawable/custom_temp45_shape2" />

            <ImageView
                layout_width="match_parent"
                layout_height="match_parent"
                scaleType="fitXY"
                src="@drawable/custom_temp45_shape2_stroke" />

        </FrameLayout>

        <FrameLayout
            layout_width="@dimen/_110sdp"
            layout_height="@dimen/_130sdp"
            layout_marginStart="@dimen/_100sdp"
            layout_marginTop="@dimen/_70sdp"
            elevation="@dimen/_3sdp"
            rotation="10"
            >

            <com.editor.template.utils.CollageShapeView
                id="@+id/shape4"
                layout_width="match_parent"
                layout_height="match_parent"
                layout_margin="@dimen/_8sdp"
                shapeDrawable="@drawable/custom_temp45_shape1" />

            <ImageView
                layout_width="match_parent"
                layout_height="match_parent"
                scaleType="fitXY"
                src="@drawable/custom_temp45_shape1_stroke" />

        </FrameLayout>

    </RelativeLayout>



</RelativeLayout>