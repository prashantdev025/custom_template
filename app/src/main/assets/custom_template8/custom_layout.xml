<RelativeLayout 
    id="@+id/main"
    layout_width="match_parent"
    layout_height="@dimen/_350sdp"
    layout_gravity="center_vertical"
    >


    <ImageView
        layout_width="match_parent"
        layout_height="match_parent"
        scaleType="fitXY"
        src="@drawable/ic_bg_temp6" />


    <RelativeLayout
        layout_width="match_parent"
        layout_height="@dimen/_225sdp"
        layout_centerInParent="true"
        layout_marginHorizontal="@dimen/_10sdp">
        <LinearLayout
            layout_width="match_parent"
            layout_height="@dimen/_160sdp"
            layout_alignParentBottom="true"
            layout_marginHorizontal="@dimen/_25sdp"
            orientation="horizontal"
            layout_marginBottom="@dimen/_10sdp"
            weightSum="4">

            <FrameLayout
                layout_width="0dp"
                layout_height="match_parent"
                layout_weight="1.3"
                padding="@dimen/_4sdp">

                <com.appblish.templates.TemplateShapeView
                    id="@+id/shape1"
                    layout_width="match_parent"
                    layout_height="match_parent"
                    shapeDrawable="@drawable/custom_temp6_l1" />

                <ImageView
                    layout_width="match_parent"
                    layout_height="match_parent"
                    scaleType="fitXY"
                    src="@drawable/custom_temp6_l1_stroke" />

            </FrameLayout>

            <LinearLayout
                layout_width="0dp"
                layout_height="match_parent"
                layout_weight="2.7"
                orientation="vertical"
                weightSum="3">

                <FrameLayout
                    layout_width="match_parent"
                    layout_height="0dp"
                    layout_weight="1.2"
                    padding="@dimen/_4sdp">

                    <com.appblish.templates.TemplateShapeView
                        id="@+id/shape2"
                        layout_width="match_parent"
                        layout_height="match_parent"
                        shapeDrawable="@drawable/custom_temp6_l2" />

                    <ImageView
                        layout_width="match_parent"
                        layout_height="match_parent"
                        scaleType="fitXY"
                        src="@drawable/custom_temp6_l2_stroke" />

                </FrameLayout>


                <LinearLayout
                    layout_width="match_parent"
                    layout_height="0dp"
                    layout_weight="1.8"
                    orientation="horizontal"
                    weightSum="3">

                    <FrameLayout
                        layout_width="0dp"
                        layout_height="match_parent"
                        layout_weight="1.4"
                        padding="@dimen/_4sdp">

                        <com.appblish.templates.TemplateShapeView
                            id="@+id/shape3"
                            layout_width="match_parent"
                            layout_height="match_parent"
                            shapeDrawable="@drawable/custom_temp6_l3" />

                        <ImageView
                            layout_width="match_parent"
                            layout_height="match_parent"
                            scaleType="fitXY"
                            src="@drawable/custom_temp6_l3_stroke" />

                    </FrameLayout>

                    <LinearLayout
                        layout_width="0dp"
                        layout_height="match_parent"
                        layout_weight="1.6"
                        orientation="vertical"
                        weightSum="2">

                        <LinearLayout
                            layout_width="match_parent"
                            layout_height="0dp"
                            layout_weight="0.9"
                            weightSum="2">

                            <FrameLayout
                                layout_width="0dp"
                                layout_height="match_parent"
                                layout_weight="1"
                                padding="@dimen/_4sdp">

                                <com.appblish.templates.TemplateShapeView
                                    id="@+id/shape5"
                                    layout_width="match_parent"
                                    layout_height="match_parent"
                                    shapeDrawable="@drawable/custom_temp6_l5" />

                                <ImageView
                                    layout_width="match_parent"
                                    layout_height="match_parent"
                                    scaleType="fitXY"
                                    src="@drawable/custom_temp6_l5_stroke" />

                            </FrameLayout>

                            <FrameLayout
                                layout_width="0dp"
                                layout_height="match_parent"
                                layout_weight="1"
                                padding="@dimen/_4sdp">

                                <com.appblish.templates.TemplateShapeView
                                    id="@+id/shape6"
                                    layout_width="match_parent"
                                    layout_height="match_parent"
                                    shapeDrawable="@drawable/custom_temp6_l5" />

                                <ImageView
                                    layout_width="match_parent"
                                    layout_height="match_parent"
                                    scaleType="fitXY"
                                    src="@drawable/custom_temp6_l5_stroke" />

                            </FrameLayout>
                        </LinearLayout>

                        <FrameLayout
                            layout_width="match_parent"
                            layout_height="0dp"
                            layout_weight="1.1"
                            padding="@dimen/_4sdp">

                            <com.appblish.templates.TemplateShapeView
                                id="@+id/shape4"
                                layout_width="match_parent"
                                layout_height="match_parent"
                                shapeDrawable="@drawable/custom_temp6_l4" />

                            <ImageView
                                layout_width="match_parent"
                                layout_height="match_parent"
                                scaleType="fitXY"
                                src="@drawable/custom_temp6_l4_stroke" />

                        </FrameLayout>
                    </LinearLayout>


                </LinearLayout>

            </LinearLayout>


        </LinearLayout>

        <ImageView
            layout_width="@dimen/_20sdp"
            layout_height="@dimen/_20sdp"
            layout_marginStart="@dimen/_95sdp"
            layout_marginTop="@dimen/_125sdp"
            src="@drawable/ic_blue_pop_temp6" />

        <ImageView
            layout_width="@dimen/_40sdp"
            layout_height="@dimen/_40sdp"
            layout_alignParentEnd="true"
            layout_marginTop="@dimen/_95sdp"
            layout_marginEnd="@dimen/_5sdp"
            src="@drawable/ic_red_pop_temp6" />
        <ImageView
            layout_width="@dimen/_22sdp"
            layout_height="@dimen/_22sdp"
            layout_marginStart="@dimen/_170sdp"
            layout_marginTop="@dimen/_170sdp"
            src="@drawable/ic_yellow_pop_temp6" />
    </RelativeLayout>



</RelativeLayout>