<RelativeLayout 
    id="@+id/main"
    layout_width="match_parent"
    layout_height="@dimen/_350sdp"
    layout_gravity="center_vertical"
    >


    <ImageView
        layout_width="match_parent"
        layout_height="match_parent"
        src="@drawable/ic_temp10_bg"
        scaleType="fitXY"
        />


    <RelativeLayout
        layout_width="wrap_content"
        layout_height="@dimen/_115sdp"
        layout_centerInParent="true"
        >
        <FrameLayout
            layout_width="@dimen/_200sdp"
            layout_height="@dimen/_100sdp"
          >

            <com.appblish.templates.TemplateShapeView
                id="@+id/shape1"
                layout_width="match_parent"
                layout_height="match_parent"
                shapeDrawable="@drawable/custom_temp10_shape" />

            <ImageView
                layout_width="match_parent"
                layout_height="match_parent"
                scaleType="fitXY"
                src="@drawable/custom_temp10_shape_stroke" />

        </FrameLayout>
    </RelativeLayout>

</RelativeLayout>