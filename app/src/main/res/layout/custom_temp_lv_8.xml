<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="@dimen/_350sdp"
    android:layout_gravity="center_vertical"
    tools:context=".MainActivity">


    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/ic_bg_temp6" />


    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/_225sdp"
        android:layout_centerInParent="true"
        android:layout_marginHorizontal="@dimen/_10sdp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/_160sdp"
            android:layout_alignParentBottom="true"
            android:layout_marginHorizontal="@dimen/_25sdp"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/_10sdp"
            android:weightSum="4">

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.3"
                android:padding="@dimen/_4sdp">

                <com.editor.template.utils.CollageShapeView
                    android:id="@+id/shape1"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:shapeDrawable="@drawable/custom_temp6_l1" />

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"
                    android:src="@drawable/custom_temp6_l1_stroke" />

            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2.7"
                android:orientation="vertical"
                android:weightSum="3">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1.2"
                    android:padding="@dimen/_4sdp">

                    <com.editor.template.utils.CollageShapeView
                        android:id="@+id/shape2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:shapeDrawable="@drawable/custom_temp6_l2" />

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitXY"
                        android:src="@drawable/custom_temp6_l2_stroke" />

                </FrameLayout>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1.8"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1.4"
                        android:padding="@dimen/_4sdp">

                        <com.editor.template.utils.CollageShapeView
                            android:id="@+id/shape3"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            app:shapeDrawable="@drawable/custom_temp6_l3" />

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitXY"
                            android:src="@drawable/custom_temp6_l3_stroke" />

                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1.6"
                        android:orientation="vertical"
                        android:weightSum="2">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="0.9"
                            android:weightSum="2">

                            <FrameLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:padding="@dimen/_4sdp">

                                <com.editor.template.utils.CollageShapeView
                                    android:id="@+id/shape5"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    app:shapeDrawable="@drawable/custom_temp6_l5" />

                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="fitXY"
                                    android:src="@drawable/custom_temp6_l5_stroke" />

                            </FrameLayout>

                            <FrameLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:padding="@dimen/_4sdp">

                                <com.editor.template.utils.CollageShapeView
                                    android:id="@+id/shape6"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    app:shapeDrawable="@drawable/custom_temp6_l5" />

                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="fitXY"
                                    android:src="@drawable/custom_temp6_l5_stroke" />

                            </FrameLayout>
                        </LinearLayout>

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1.1"
                            android:padding="@dimen/_4sdp">

                            <com.editor.template.utils.CollageShapeView
                                android:id="@+id/shape4"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                app:shapeDrawable="@drawable/custom_temp6_l4" />

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="fitXY"
                                android:src="@drawable/custom_temp6_l4_stroke" />

                        </FrameLayout>
                    </LinearLayout>


                </LinearLayout>

            </LinearLayout>


        </LinearLayout>

        <ImageView
            android:layout_width="@dimen/_20sdp"
            android:layout_height="@dimen/_20sdp"
            android:layout_marginStart="@dimen/_95sdp"
            android:layout_marginTop="@dimen/_125sdp"
            android:src="@drawable/ic_blue_pop_temp6" />

        <ImageView
            android:layout_width="@dimen/_40sdp"
            android:layout_height="@dimen/_40sdp"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="@dimen/_95sdp"
            android:layout_marginEnd="@dimen/_5sdp"
            android:src="@drawable/ic_red_pop_temp6" />
        <ImageView
            android:layout_width="@dimen/_22sdp"
            android:layout_height="@dimen/_22sdp"
            android:layout_marginStart="@dimen/_170sdp"
            android:layout_marginTop="@dimen/_170sdp"
            android:src="@drawable/ic_yellow_pop_temp6" />
    </RelativeLayout>



</RelativeLayout>