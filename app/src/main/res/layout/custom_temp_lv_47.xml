<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="@dimen/_165sdp"
    android:layout_gravity="center_vertical">


    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/frame47_bg" />

    <RelativeLayout
        android:layout_width="@dimen/_220sdp"
        android:layout_height="@dimen/_140sdp"
        android:layout_centerVertical="true"
        android:layout_marginStart="@dimen/_15sdp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/_5sdp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="@dimen/_70sdp"
                android:layout_height="@dimen/_140sdp"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">

                    <com.editor.template.utils.CollageShapeView
                        android:id="@+id/shape1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:shapeDrawable="@drawable/custom_temp47_shape1" />

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitXY"
                        android:src="@drawable/custom_temp47_shape1_stroke" />

                </FrameLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">

                    <com.editor.template.utils.CollageShapeView
                        android:id="@+id/shape2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:shapeDrawable="@drawable/custom_temp47_shape1" />

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitXY"
                        android:src="@drawable/custom_temp47_shape2_stroke" />

                </FrameLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="@dimen/_60sdp"
                android:layout_height="@dimen/_120sdp"
                android:layout_marginStart="@dimen/_7sdp"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">

                    <com.editor.template.utils.CollageShapeView
                        android:id="@+id/shape3"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:shapeDrawable="@drawable/custom_temp47_shape1" />

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitXY"
                        android:src="@drawable/custom_temp47_shape1_stroke" />

                </FrameLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">

                    <com.editor.template.utils.CollageShapeView
                        android:id="@+id/shape4"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:shapeDrawable="@drawable/custom_temp47_shape1" />

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitXY"
                        android:src="@drawable/custom_temp47_shape2_stroke" />

                </FrameLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="@dimen/_50sdp"
                android:layout_height="@dimen/_100sdp"
                android:layout_marginStart="@dimen/_7sdp"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">

                    <com.editor.template.utils.CollageShapeView
                        android:id="@+id/shape5"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:shapeDrawable="@drawable/custom_temp47_shape1" />

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitXY"
                        android:src="@drawable/custom_temp47_shape1_stroke" />

                </FrameLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">

                    <com.editor.template.utils.CollageShapeView
                        android:id="@+id/shape6"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:shapeDrawable="@drawable/custom_temp47_shape1" />

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitXY"
                        android:src="@drawable/custom_temp47_shape2_stroke" />

                </FrameLayout>

            </LinearLayout>

        </LinearLayout>

        <ImageView
            android:layout_width="@dimen/_35sdp"
            android:layout_height="@dimen/_35sdp"
            android:adjustViewBounds="true"
            android:layout_alignParentEnd="true"
            android:src="@drawable/frame47_ele2" />

        <ImageView
            android:layout_width="@dimen/_10sdp"
            android:layout_height="@dimen/_10sdp"
            android:adjustViewBounds="true"
            android:layout_marginTop="@dimen/_10sdp"
            android:src="@drawable/frame47_ele4" />

        <ImageView
            android:layout_width="@dimen/_10sdp"
            android:layout_height="@dimen/_10sdp"
            android:adjustViewBounds="true"
            android:layout_marginBottom="@dimen/_25sdp"
            android:layout_alignParentBottom="true"
            android:src="@drawable/frame47_ele4" />
        <ImageView
            android:layout_width="@dimen/_10sdp"
            android:layout_height="@dimen/_10sdp"
            android:adjustViewBounds="true"
            android:layout_marginStart="@dimen/_75sdp"
            android:layout_marginTop="@dimen/_35sdp"
            android:src="@drawable/frame47_ele4" />
        <ImageView
            android:layout_width="@dimen/_10sdp"
            android:layout_height="@dimen/_10sdp"
            android:adjustViewBounds="true"
            android:layout_marginEnd="@dimen/_72sdp"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="@dimen/_45sdp"
            android:src="@drawable/frame47_ele4" />
        <ImageView
            android:layout_width="@dimen/_10sdp"
            android:layout_height="@dimen/_10sdp"
            android:adjustViewBounds="true"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="@dimen/_65sdp"
            android:layout_marginEnd="@dimen/_15sdp"
            android:src="@drawable/frame47_ele4" />
    </RelativeLayout>




    <ImageView
        android:layout_width="@dimen/_140sdp"
        android:layout_height="@dimen/_90sdp"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="@dimen/_55sdp"
        android:layout_marginBottom="@dimen/_5sdp"
        android:adjustViewBounds="true"
        android:src="@drawable/frame47_ele1" />


    <ImageView
        android:layout_width="@dimen/_45sdp"
        android:layout_height="@dimen/_45sdp"
        android:layout_marginStart="@dimen/_75sdp"
        android:adjustViewBounds="true"
        android:padding="@dimen/_6sdp"
        android:src="@drawable/frame47_ele3" />


</RelativeLayout>