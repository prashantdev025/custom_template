<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="@dimen/_350sdp"
    android:layout_gravity="center_vertical"
    >


    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/ic_temp11_bg" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="@dimen/_60sdp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:orientation="horizontal"
            android:weightSum="2"
            android:padding="@dimen/_3sdp"
            android:layout_weight="1">
            <FrameLayout
                android:layout_width="@dimen/_90sdp"
                android:layout_height="@dimen/_90sdp"
                >

                <com.editor.template.utils.CollageShapeView
                    android:id="@+id/shape1"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:shapeDrawable="@drawable/custum_temp11_shape1" />

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"
                    android:src="@drawable/custum_temp11_shape1_strock" />

            </FrameLayout>
            <LinearLayout
                android:layout_width="@dimen/_45sdp"
                android:layout_height="@dimen/_90sdp"
                android:orientation="vertical"
                android:weightSum="2"
                >
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_weight="1"
                    android:padding="@dimen/_3sdp"
                    android:layout_height="0dp"
                    >

                    <com.editor.template.utils.CollageShapeView
                        android:id="@+id/shape3"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:shapeDrawable="@drawable/custum_temp11_shape1" />

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitXY"
                        android:src="@drawable/custum_temp11_shape1_strock" />

                </FrameLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_weight="1"
                    android:padding="@dimen/_3sdp"
                    android:layout_height="0dp"
                    >

                    <com.editor.template.utils.CollageShapeView
                        android:id="@+id/shape2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:shapeDrawable="@drawable/custum_temp11_shape1" />

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitXY"
                        android:src="@drawable/custum_temp11_shape1_strock" />

                </FrameLayout>
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:orientation="horizontal"
            android:weightSum="2"
            android:padding="@dimen/_3sdp"
            android:layout_weight="1">
            <LinearLayout
                android:layout_width="@dimen/_45sdp"
                android:layout_height="@dimen/_90sdp"
                android:orientation="vertical"
                android:weightSum="2"
                >
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_weight="1"
                    android:padding="@dimen/_3sdp"
                    android:layout_height="0dp"
                    >

                    <com.editor.template.utils.CollageShapeView
                        android:id="@+id/shape4"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:shapeDrawable="@drawable/custum_temp11_shape1" />

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitXY"
                        android:src="@drawable/custum_temp11_shape1_strock" />

                </FrameLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_weight="1"
                    android:padding="@dimen/_3sdp"
                    android:layout_height="0dp"
                    >

                    <com.editor.template.utils.CollageShapeView
                        android:id="@+id/shape5"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:shapeDrawable="@drawable/custum_temp11_shape1" />

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitXY"
                        android:src="@drawable/custum_temp11_shape1_strock" />

                </FrameLayout>
            </LinearLayout>
            <FrameLayout
                android:layout_width="@dimen/_90sdp"
                android:layout_height="@dimen/_90sdp"
                >

                <com.editor.template.utils.CollageShapeView
                    android:id="@+id/shape6"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:shapeDrawable="@drawable/custum_temp11_shape1" />

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"
                    android:src="@drawable/custum_temp11_shape1_strock" />

            </FrameLayout>


        </LinearLayout>

    </LinearLayout>


</RelativeLayout>